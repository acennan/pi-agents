{
  "name": "pi-agents",
  "version": "1.0.0",
  "description": "",
  "private": true,
  "type": "module",
  "main": "extensions/team/index.js",
  "scripts": {
    "build": "tsc",
    "clean": "bun run clean --workspaces",
    "watch:build": "tsc --watch",
    "typecheck": "tsc -p tsconfig.json",
    "format": "bun biome format --write ./extensions",
    "lint": "bun biome lint --write ./extensions",
    "check": "bun biome check --write ./extensions",
    "dead-code": "fallow dead-code",
    "duplication": "fallow dupes",
    "health": "fallow health",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest --watch"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/acennan/pi-agents.git"
  },
  "author": "Damian Jackson",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/acennan/pi-agents/issues"
  },
  "homepage": "https://github.com/acennan/pi-agents#readme",
  "devDependencies": {
    "@biomejs/biome": "2.4.10",
    "@types/bun": "^1.3.11",
    "@types/proper-lockfile": "^4.1.4",
    "@vitest/coverage-v8": "4.1.0",
    "fallow": "^2.11.0",
    "globals": "^17.4.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "@mariozechner/pi-ai": "^0.64.0",
    "@mariozechner/pi-coding-agent": "^0.64.0",
    "@mariozechner/pi-tui": "^0.64.0",
    "proper-lockfile": "^4.1.2",
    "yaml": "^2.8.3",
    "zod": "3.23.8"
  }
